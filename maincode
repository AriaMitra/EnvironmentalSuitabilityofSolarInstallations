def make_labels_from_scores(scores, hab_fracs, tau_h):
    q1, q2 = np.quantile(scores, [1/3, 2/3])

    y = np.zeros(len(scores), dtype=np.int64)          # 0=Low
    y[(scores > q1) & (scores < q2)] = 1               # 1=Med
    y[scores >= q2] = 2                                # 2=High

    y[hab_fracs > tau_h] = 0

    return y, q1, q2



