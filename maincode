def make_loaders(X_tr, y_tr, X_val, y_val, X_te, y_te, batch=BATCH):
    train_ds = TensorDataset(torch.from_numpy(X_tr), torch.from_numpy(y_tr))
    val_ds   = TensorDataset(torch.from_numpy(X_val), torch.from_numpy(y_val))
    test_ds  = TensorDataset(torch.from_numpy(X_te), torch.from_numpy(y_te))

    train_loader = DataLoader(train_ds, batch_size=batch, shuffle=True)
    train_eval_loader = DataLoader(train_ds, batch_size=batch, shuffle=False)  
    val_loader  = DataLoader(val_ds, batch_size=batch, shuffle=False)
    test_loader = DataLoader(test_ds, batch_size=batch, shuffle=False)
    return train_loader, train_eval_loader, val_loader, test_loader

def train_one_fold(X_tr, y_tr, X_val, y_val, fold_dir):
    os.makedirs(fold_dir, exist_ok=True)

    train_loader, train_eval_loader, val_loader, _ = make_loaders(
        X_tr, y_tr, X_val, y_val, X_val[:1], y_val[:1]  
    )

    model = SuitabilityCNN().to(device)
    criterion = nn.CrossEntropyLoss()
    optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
        optimizer, mode="min", factor=0.5, patience=3
    )

    def eval_loader(loader):
        model.eval()
        tot_loss, correct, total = 0.0, 0, 0
        with torch.no_grad():
            for xb, yb in loader:
                xb, yb = xb.to(device), yb.to(device)
                logits = model(xb)
                loss = criterion(logits, yb)
                tot_loss += loss.item() * xb.size(0)
                pred = logits.argmax(dim=1)
                correct += (pred == yb).sum().item()
                total += yb.numel()
        return tot_loss / max(1, total), correct / max(1, total)

    best_val = float("inf")
    bad_epochs = 0
    best_path = os.path.join(fold_dir, "best_by_val_loss.pt")

    train_losses, val_losses = [], []
    train_accs, val_accs = [], []

    for ep in range(1, EPOCHS + 1):
        model.train()
        running = 0.0

        for xb, yb in train_loader:
            xb, yb = xb.to(device), yb.to(device)
            optimizer.zero_grad()
            logits = model(xb)
            loss = criterion(logits, yb)
            loss.backward()
            if GRAD_CLIP is not None:
                torch.nn.utils.clip_grad_norm_(model.parameters(), GRAD_CLIP)
            optimizer.step()
            running += loss.item() * xb.size(0)

        train_loss = running / len(train_loader.dataset)
        val_loss, val_acc = eval_loader(val_loader)
        _, train_acc = eval_loader(train_eval_loader)

        scheduler.step(val_loss)

        train_losses.append(train_loss)
        val_losses.append(val_loss)
        train_accs.append(train_acc)
        val_accs.append(val_acc)

        lr_now = optimizer.param_groups[0]["lr"]
        print(
            f"  Epoch {ep:02d}/{EPOCHS} | lr {lr_now:.2e} | "
            f"train loss {train_loss:.4f} acc {train_acc:.3f} | "
            f"val loss {val_loss:.4f} acc {val_acc:.3f}"
        )

        if val_loss < best_val - 1e-4:
            best_val = val_loss
            bad_epochs = 0
            torch.save(model.state_dict(), best_path)
        else:
            bad_epochs += 1
            if bad_epochs >= PATIENCE:
                print(f"  Early stopping (best val loss {best_val:.4f})")
                break

   
    np.save(os.path.join(fold_dir, "train_losses.npy"), np.array(train_losses))
    np.save(os.path.join(fold_dir, "val_losses.npy"), np.array(val_losses))
    np.save(os.path.join(fold_dir, "train_accs.npy"), np.array(train_accs))
    np.save(os.path.join(fold_dir, "val_accs.npy"), np.array(val_accs))
    import matplotlib.pyplot as plt

    plt.figure()
    plt.plot(train_losses, label="train")
    plt.plot(val_losses, label="val")
    plt.title("Loss Curves")
    plt.xlabel("Epoch")
    plt.ylabel("Cross-Entropy Loss")
    plt.legend()
    plt.show()

    plt.figure()
    plt.plot(train_accs, label="train")
    plt.plot(val_accs, label="val")
    plt.title("Accuracy Curves")
    plt.xlabel("Epoch")
    plt.ylabel("Classification Accuracy")
    plt.legend()
    plt.show()
    return best_path

def predict_loader(model, loader):
    model.eval()
    preds, trues = [], []
    with torch.no_grad():
        for xb, yb in loader:
            xb = xb.to(device)
            logits = model(xb)
            p = logits.argmax(dim=1).cpu().numpy()
            preds.append(p)
            trues.append(yb.numpy())
    return np.concatenate(trues), np.concatenate(preds)

def compute_metrics(y_true, y_pred):
    acc = accuracy_score(y_true, y_pred)
    macro_f1 = f1_score(y_true, y_pred, average="macro")
    macro_precision = precision_score(y_true, y_pred, average="macro")
    bal_acc  = balanced_accuracy_score(y_true, y_pred)
    recalls  = recall_score(y_true, y_pred, average=None, labels=[0,1,2])
    precisions = precision_score(y_true, y_pred, average=None, labels=[0,1,2])
    return {
        "accuracy": float(acc),
        "macro_f1": float(macro_f1),
        "macro_precision": float(macro_precision),
        "balanced_accuracy": float(bal_acc),
        "recall_low": float(recalls[0]),
        "recall_med": float(recalls[1]),
        "recall_high": float(recalls[2]),
        "precision_low": float(precisions[0]),
        "precision_med": float(precisions[1]),
        "precision_high": float(precisions[2]),
    }





def nearest_train_test_distance(rows_kept, cols_kept, train_idx, test_idx, pixel_size_m=30.0):
    train_rows = rows_kept[train_idx].astype(np.float64)
    train_cols = cols_kept[train_idx].astype(np.float64)

    test_rows = rows_kept[test_idx].astype(np.float64)
    test_cols = cols_kept[test_idx].astype(np.float64)

    nearest_dist_pixels = []

    for rr, cc in zip(test_rows, test_cols):
        d = np.sqrt((train_rows - rr) ** 2 + (train_cols - cc) ** 2)
        nearest_dist_pixels.append(np.min(d))

    nearest_dist_pixels = np.array(nearest_dist_pixels, dtype=np.float64)
    nearest_dist_km = nearest_dist_pixels * pixel_size_m / 1000.0

    return {
        "min_km": float(np.min(nearest_dist_km)),
        "mean_km": float(np.mean(nearest_dist_km)),
        "median_km": float(np.median(nearest_dist_km)),
        "max_km": float(np.max(nearest_dist_km)),
    }


def morans_i_on_errors(rows, cols, y_true, y_pred, k=8):
    

    coords = np.column_stack([cols, rows]).astype(float)
    residual_error = (y_true != y_pred).astype(float)


    if np.all(residual_error == residual_error[0]):
        return {
            "moran_I": np.nan,
            "moran_p": np.nan,
            "note": "Residuals constant; Moran's I undefined."
        }

   
    k_use = min(k, len(coords) - 1)

    w = KNN.from_array(coords, k=k_use)
    w.transform = "r"

    mi = Moran(residual_error, w)

    return {
        "moran_I": float(mi.I),
        "moran_p": float(mi.p_sim),
        "note": "Computed on binary prediction errors."
    }



