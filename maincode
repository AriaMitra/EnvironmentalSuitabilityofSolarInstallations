class SuitabilityCNN(nn.Module):
    def __init__(self):
        super().__init__()
        self.c1a = nn.Conv2d(3, 32, 3, padding=1)
        self.c1b = nn.Conv2d(32, 32, 3, padding=1)

        self.c2a = nn.Conv2d(32, 64, 3, padding=1)
        self.c2b = nn.Conv2d(64, 64, 3, padding=1)

        self.c3a = nn.Conv2d(64, 128, 3, padding=1)
        self.c3b = nn.Conv2d(128, 128, 3, padding=1)

        self.pool = nn.MaxPool2d(2, 2)
        self.gap = nn.AdaptiveAvgPool2d((1, 1))
        self.fc1 = nn.Linear(128, 64)
        self.drop = nn.Dropout(0.3)
        self.fc2 = nn.Linear(64, 3)

    def forward(self, x):
        x = F.relu(self.c1a(x))
        x = F.relu(self.c1b(x))
        x = self.pool(x)

        x = F.relu(self.c2a(x))
        x = F.relu(self.c2b(x))
        x = self.pool(x)

        x = F.relu(self.c3a(x))
        x = F.relu(self.c3b(x))
        x = self.pool(x)

        x = self.gap(x)
        x = x.view(x.size(0), -1)
        x = F.relu(self.fc1(x))
        x = self.drop(x)
        return self.fc2(x)  
        
